

=== ALL AOB SIGNATURES (PATTERNS) ===
8B B2 D0 7B 00 00                 → Main Hook (Total Studs pointer)
D9 05 6C CA 9C 00 D9              → Hide Character Portraits
D9 05 50 08 AB 00 D9              → Hide Super Bar
D9 05 A8 CA 9C 00 D9 1C           → Hide Stud Counter
8B 0D 24 6F AC 00 D9              → Hide Game Hints
0F BE 80 C7 15 00 00              → Quick Boss Encounters


=== MAIN HOOK SCRIP ===
[ENABLE]
aobscanmodule(One,LEGOBatman.exe,8B B2 D0 7B 00 00)
alloc(newmem,$1000)
alloc(Two,4)
registersymbol(One)
registersymbol(Two)
label(code)
label(return)
Two:
  dd 0
newmem:
code:
  mov [Two],edx
  mov esi,[edx+00007BD0]
  jmp return
One:
  jmp newmem
  nop
return:
[DISABLE]
One:
  db 8B B2 D0 7B 00 00
unregistersymbol(One)
unregistersymbol(Two)
dealloc(newmem)
dealloc(Two)


