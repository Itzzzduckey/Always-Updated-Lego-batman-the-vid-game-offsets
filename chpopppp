3. TELEPORT SCRIPTS (LUA)
================================================================================

-- Get Player Position Pointer
local Pl = getAddressSafe("[[P_Base]+290]+1D0")

-- Teleport to Train
local Tr = getAddressSafe("[[[P_Base]+760]+130]+11C")
writeFloat(Pl, readFloat(Tr))
writeFloat(Pl+0x4, readFloat(Tr+0x4))
writeFloat(Pl+0x8, readFloat(Tr+0x8) + 150)

-- Teleport to Waypoint
local Wp = getAddressSafe("[WayPoint_]+11C")
writeFloat(Pl, readFloat(Wp))
writeFloat(Pl+0x4, readFloat(Wp+0x4))
writeFloat(Pl+0x8, readFloat(Wp+0x8) + 100)

