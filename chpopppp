5. MAIN CHEATS (LUA / AA)
================================================================================

-- God Mode / Infinite HP
writeFloat(P_Base + 0x6C4, 999999)

-- Max Player Speeds
writeFloat(P_Base + 0x608, 9999)   -- Sprint
writeFloat(P_Base + 0x60C, 9999)   -- Walk
writeFloat([[P_Base]+288]+0x158, 9999) -- Jump

-- Train God Mode
local Train = getAddressSafe("[[P_Base]+760]")
writeFloat(Train + 0x7D4, 999999)   -- Forward Speed
writeFloat(Train + 0x7D8, 999999)   -- Backward Speed
writeFloat(Train + 0x818, 999999)   -- Acceleration

-- No Weapon Overheat / Jam
local MGJam  = Train + 0xA08
local RGJam  = Train + 0xA20
local FTJam  = Train + 0xA2C
writeFloat(MGJam, 0)
writeFloat(RGJam, 0)
writeFloat(FTJam, 0)

-- One-Hit Kill Weapons
writeFloat(Train + 0x968, 999999)  -- MG DMG
writeFloat(Train + 0x96C, 999999)  -- Range Gun DMG

-- Charles Can't Hurt You
writeByte([[P_Base]+8C0] + 0x891, 0)

-- Charles Max DMG (for fun)
writeFloat([[P_Base]+8C0] + 0x754, 999999) -- Face
writeFloat([[P_Base]+8C0] + 0x758, 999999) -- Body
writeFloat([[P_Base]+8C0] + 0x75C, 999999) -- Legs

